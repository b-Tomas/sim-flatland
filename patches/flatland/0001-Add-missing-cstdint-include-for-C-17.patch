From 30c9e87452a084fc8d36b46f9a12080848cd0c89 Mon Sep 17 00:00:00 2001
From: Flatland Patcher <patcher@openrobops.local>
Date: Mon, 20 Apr 2026 08:56:13 -0300
Subject: [PATCH 01/12] Add missing <cstdint> include for C++17

C++17 no longer implicitly includes <cstdint>, so uint16_t etc.
are no longer visible through transitive includes on newer
compilers (GCC 13+, Ubuntu 24.04).
---
 .../include/flatland_server/collision_filter_registry.h          | 1 +
 1 file changed, 1 insertion(+)

diff --git a/flatland_server/include/flatland_server/collision_filter_registry.h b/flatland_server/include/flatland_server/collision_filter_registry.h
index 934b01e..361a03c 100644
--- a/flatland_server/include/flatland_server/collision_filter_registry.h
+++ b/flatland_server/include/flatland_server/collision_filter_registry.h
@@ -1,3 +1,4 @@
+#include <cstdint>
 /*
