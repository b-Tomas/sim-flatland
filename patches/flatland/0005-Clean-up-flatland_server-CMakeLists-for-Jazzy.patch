From ac3f7a417df952a45065c18f8b27a16efc13e585 Mon Sep 17 00:00:00 2001
From: Flatland Patcher <patcher@openrobops.local>
Date: Mon, 20 Apr 2026 08:56:37 -0300
Subject: [PATCH 05/12] Clean up flatland_server CMakeLists for Jazzy

- Move ament_package() to end of file (must come after all
  install() calls under ament_cmake >= rolling/jazzy).
- Remove broken ament_export_interfaces/ament_export_targets
  (ament_export_libraries already handles library exports).
- Drop the now-unused EXPORT export_flatland_lib argument from
  install(TARGETS ...).
---
 flatland_server/CMakeLists.txt | 5 ++---
 1 file changed, 2 insertions(+), 3 deletions(-)

diff --git a/flatland_server/CMakeLists.txt b/flatland_server/CMakeLists.txt
index b1c3425..66bc94e 100644
--- a/flatland_server/CMakeLists.txt
+++ b/flatland_server/CMakeLists.txt
@@ -124,7 +124,6 @@ target_link_libraries(flatland_server
 )
 
 
-ament_export_interfaces(export_flatland_lib HAS_LIBRARY_TARGET)
 ament_export_libraries(flatland_lib)
 ament_export_dependencies(rclcpp flatland_msgs yaml_cpp_vendor pluginlib geometry_msgs std_srvs tf2 tf2_ros tf2_geometry_msgs)
 ament_export_include_directories(include)
@@ -201,7 +200,6 @@ endif()
 endif()
 
 
-ament_package()
 
 #############
 ## Install ##
@@ -211,7 +209,7 @@ pluginlib_export_plugin_description_file(flatland_lib plugin_description.xml)
 
 install(
   TARGETS flatland_lib
-  EXPORT export_flatland_lib
+  
   LIBRARY DESTINATION lib
   ARCHIVE DESTINATION lib
   RUNTIME DESTINATION bin
@@ -243,3 +241,4 @@ install(DIRECTORY test/conestogo_office_test
 #install(FILES flatland_plugins.xml
 #    DESTINATION ${CATKIN_PACKAGE_SHARE_DESTINATION}
 #)
+ament_package()
