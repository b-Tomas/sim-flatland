From d85df267d928dfb6a296818f328330ea9f6f1ddd Mon Sep 17 00:00:00 2001
From: Flatland Patcher <patcher@openrobops.local>
Date: Mon, 20 Apr 2026 08:56:26 -0300
Subject: [PATCH 03/12] Use tf2_geometry_msgs .hpp header path for ROS2

In ROS2, tf2_geometry_msgs/tf2_geometry_msgs.h was renamed to
tf2_geometry_msgs/tf2_geometry_msgs.hpp. Jazzy removes the .h
alias entirely.
---
 flatland_plugins/src/diff_drive.cpp         | 2 +-
 flatland_plugins/src/tricycle_drive.cpp     | 2 +-
 flatland_server/src/debug_visualization.cpp | 2 +-
 3 files changed, 3 insertions(+), 3 deletions(-)

diff --git a/flatland_plugins/src/diff_drive.cpp b/flatland_plugins/src/diff_drive.cpp
index 3425f3c..50101c0 100644
--- a/flatland_plugins/src/diff_drive.cpp
+++ b/flatland_plugins/src/diff_drive.cpp
@@ -53,7 +53,7 @@
 #include <pluginlib/class_list_macros.hpp>
 #include <rclcpp/rclcpp.hpp>
 #include <tf2/convert.h>
-#include <tf2_geometry_msgs/tf2_geometry_msgs.h>
+#include <tf2_geometry_msgs/tf2_geometry_msgs.hpp>
 
 namespace flatland_plugins {
 
diff --git a/flatland_plugins/src/tricycle_drive.cpp b/flatland_plugins/src/tricycle_drive.cpp
index ceadd33..ecdf9c8 100644
--- a/flatland_plugins/src/tricycle_drive.cpp
+++ b/flatland_plugins/src/tricycle_drive.cpp
@@ -53,7 +53,7 @@
 #include <rclcpp/rclcpp.hpp>
 #include <tf2/LinearMath/Quaternion.h>
 #include <tf2/convert.h>
-#include <tf2_geometry_msgs/tf2_geometry_msgs.h>
+#include <tf2_geometry_msgs/tf2_geometry_msgs.hpp>
 #include <memory>
 
 namespace flatland_plugins {
diff --git a/flatland_server/src/debug_visualization.cpp b/flatland_server/src/debug_visualization.cpp
index c1cba5e..4e15585 100644
--- a/flatland_server/src/debug_visualization.cpp
+++ b/flatland_server/src/debug_visualization.cpp
@@ -49,7 +49,7 @@
 #include <rclcpp/rclcpp.hpp>
 #include <tf2/LinearMath/Quaternion.h>
 #include <tf2/convert.h>
-#include <tf2_geometry_msgs/tf2_geometry_msgs.h>
+#include <tf2_geometry_msgs/tf2_geometry_msgs.hpp>
 #include <map>
 #include <string>
 
